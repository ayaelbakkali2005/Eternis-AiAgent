# .env.example

# Database
DB_USER=erp_user
DB_PASSWORD=change_this_in_production
DB_NAME=erp_db

# Security 
JWT_SECRET=your-32-char-min-secret-here
API_SECRET_KEY=your-api-secret-key-here
SECRET_KEY=your-general-secret-key-here

# AI Configuration
AI_MODEL_PATH=./models/qwen-local
AI_MOCK_MODE=false
AI_DEVICE=cpu
FAISS_INDEX_PATH=./models/faiss_index

# Redis
REDIS_URL=redis://redis:6379/0

# Logging
LOG_LEVEL=info

# Email 
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-email-password
FROM_EMAIL=noreply@example.com

# Slack 
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL