# ============================================
# AI ERP System - Environment Configuration
# Generated: 2026-07-03
# ============================================

# Application Settings
APP_NAME=AI_ERP_System
APP_VERSION=1.0.0
DEBUG=true
LOG_LEVEL=info

#  Security Keys - DO NOT USE THESE IN PRODUCTION!
JWT_SECRET=dev-jwt-secret-key-change-in-production-min-32-chars
SECRET_KEY=dev-general-secret-key-change-in-production-min-32-chars
API_SECRET_KEY=dev-api-secret-key-change-in-production-min-32-chars

#  Database Configuration
DB_USER=erp_user
DB_PASSWORD=erp_secure_pass_2024
DB_NAME=erp_db
DB_HOST=db
DB_PORT=5432

# DATABASE_URL 
DATABASE_URL=postgresql://erp_user:erp_secure_pass_123@db:5432/erp_db

# Redis/Celery Configuration
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Model Configuration
AI_MODEL_PATH=/app/models/qwen-local
AI_DEVICE=cpu
AI_MOCK_MODE=false
FAISS_INDEX_PATH=/app/models/faiss_index

# ============ Notification Settings ============
# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password  # Use app-specific password, not account password
FROM_EMAIL=noreply@eternis.com

# Slack Integration
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Celery Beat Schedule (for reminders)
CELERY_BEAT_SCHEDULE_ENABLED=true

#  VAPI Webhook Security
VAPI_WEBHOOK_SECRET=eternis_super_secret_key_2024

#  CORS Settings
ALLOWED_ORIGINS=*

#  Email Settings (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
